# NexusRoute Model Advisor — environment template
# ============================================================================
# No provider API keys are required to run the advisor. Everything below is
# optional. Copy to backend/.env for the FastAPI service or
# frontend/.env.local for the Next.js app.
# ============================================================================

# ── Backend (backend/.env) ────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./routing_platform.db
DEBUG=false
DEFAULT_OPTIMIZE_FOR=balanced

# ── Frontend (frontend/.env.local) ─────────────────────────────
# Point the frontend at a non-default backend URL.
# NEXT_PUBLIC_API_URL=http://localhost:8000/api
#
# OPTIONAL — enhanced LLM prompt interpretation.
# If set, /api/advisor/interpret will call OpenAI instead of the local
# structural interpreter. The advisor still works perfectly without it.
# OPENAI_API_KEY=sk-your-openai-key
# ADVISOR_INTERPRET_MODEL=gpt-4o-mini
