# Copy to backend/.env for local dev, or paste these into Railway's
# Variables UI for production.

# ── Database ──────────────────────────────────────────────────
# Local:
#   DATABASE_URL=sqlite+aiosqlite:///./routing_platform.db
# Production (Railway Postgres addon — add +asyncpg to the protocol!):
#   DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST.railway.internal:5432/railway
# Neon:
#   DATABASE_URL=postgresql+asyncpg://user:pwd@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=sqlite+aiosqlite:///./routing_platform.db

DEBUG=false
DEFAULT_OPTIMIZE_FOR=balanced

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated. Must include your Vercel URL in prod.
# CORS_ORIGINS=https://nexusroute.vercel.app

# ── Tier 2 enrichment (optional) ──────────────────────────────
# OPENAI_API_KEY=sk-proj-...
# TIER2_CLASSIFIER_MODEL=gpt-4o-mini
